# Copy file này thành .env.local rồi điền API key thật.
# Không chia sẻ hoặc commit file .env.local.

OPENAI_API_KEY=your_openai_api_key_here
OPENAI_OCR_MODEL=gpt-4.1-mini
OPENAI_OCR_BATCH_SIZE=3
OPENAI_MODEL=gpt-5.4-mini
OPENAI_FALLBACK_MODEL=gpt-5.4-mini
OPENAI_REASONING_EFFORT=medium
OPENAI_REQUEST_TIMEOUT_MS=120000

# Firebase Admin SDK / Firestore
# Firebase Console > Project settings > Service accounts > Generate new private key
FIREBASE_PROJECT_ID=unihubhg-tnu
FIREBASE_DATABASE_ID=(default)
FIREBASE_CLIENT_EMAIL=your_firebase_client_email_here
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nyour_private_key_here\n-----END PRIVATE KEY-----\n"

# Firebase Web App config for Authentication
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_web_api_key_here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_firebase_web_app_id_here
# Optional. Only set this if the domain is added in Firebase Authentication > Settings > Authorized domains.
# NEXT_PUBLIC_FIREBASE_AUTH_ACTION_CONTINUE_URL=https://your-domain.example/
