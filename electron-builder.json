{
  "appId": "vn.eduplan.ai",
  "productName": "EduPlan AI",
  "electronVersion": "42.5.0",
  "directories": {
    "output": "../release"
  },
  "files": [
    "**/*"
  ],
  "extraResources": [
    {
      "from": "app-config.json",
      "to": "app-config.json"
    },
    {
      "from": "../icon.png",
      "to": "icon.png"
    }
  ],
  "win": {
    "target": [
      {
        "target": "nsis",
        "arch": [
          "x64"
        ]
      }
    ],
    "icon": "../icon.png"
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true,
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true,
    "shortcutName": "EduPlan AI"
  }
}
